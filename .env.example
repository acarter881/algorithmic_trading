# Kalshi API credentials
# Generate an RSA key pair and register the public key at https://kalshi.com
AUTOTRADER__KALSHI__API_KEY_ID=your-api-key-id-here

# Private key path — only needed when running outside Docker.
# Docker Compose mounts ./kalshi_private_key.pem automatically; see docker-compose.yml.
# AUTOTRADER__KALSHI__PRIVATE_KEY_PATH=/path/to/private_key.pem

# Execution mode: paper (simulated fills) or live (real orders). Default: paper.
# AUTOTRADER__KALSHI__EXECUTION_MODE=paper

# WebSocket streaming for real-time market data (default: disabled, uses REST polling).
# When enabled, price updates arrive via a persistent WebSocket connection instead of
# periodic REST polls, reducing latency for mispricing detection.
# AUTOTRADER__KALSHI__WEBSOCKET_ENABLED=true

# Discord webhook URL for alerts
# AUTOTRADER__DISCORD__WEBHOOK_URL=https://discord.com/api/webhooks/...
# AUTOTRADER__DISCORD__ENABLED=true

# Database and logging are configured automatically in Docker via the Dockerfile
# (sqlite:////data/autotrader_paper.db, log dir /logs). Only override if you
# need a custom setup or are running outside Docker.
# AUTOTRADER__DATABASE__URL=sqlite:////data/autotrader_paper.db
# AUTOTRADER__LOGGING__LEVEL=DEBUG
